# Polymarket 交易系统配置

# ===========================================
# 必需配置 - 启用真实交易
# ===========================================

# 钱包私钥（Polygon 网络）
# 获取方式：MetaMask -> 账户详情 -> 导出私钥
# 格式：64位十六进制字符（可带或不带 0x 前缀）
# ⚠️ 警告：私钥泄露会导致资产丢失！
WALLET_PRIVATE_KEY=your_private_key_here

# Polymarket API Key
# 获取方式：https://polymarket.com/ -> 设置 -> API
POLYMARKET_API_KEY=your_api_key_here

# Polymarket API Secret
# 获取方式：同上
POLYMARKET_API_SECRET=your_api_secret_here

# ===========================================
# 可选配置 - 策略参数
# ===========================================

# 仓位大小（USDC）
# 默认：1
POSITION_SIZE=1

# 最大暴露（USDC）
# 默认：100
MAX_EXPOSURE=100

# ===========================================
# 高级配置
# ===========================================

# 配置加密密钥（可选，用于加密存储的凭证）
# 默认：polymarket-trading-default-key
# CONFIG_ENCRYPTION_KEY=your_encryption_key

# 运行环境
NODE_ENV=production
