# Polymarket API配置（必需）
# 从 https://docs.polymarket.com/ 获取
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here

# 钱包私钥（必需）
# 建议使用专用的交易钱包，不要使用主钱包
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# 策略参数（可选）
# 每次交易金额（USDC）
POSITION_SIZE=100

# 单市场最大暴露（USDC）
MAX_EXPOSURE=1000

# 环境
NODE_ENV=production
